<script>
  const DELAY = 5000;
  const PREFERS_REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll<HTMLElement>('[data-ws]').forEach((root) => {
    const sites = Array.from(root.querySelectorAll<HTMLElement>('[data-site]'));
    const pills = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-pill]'));
    const urlEl = root.querySelector<HTMLElement>('[data-ws-url]');
    const loadbar = root.querySelector<HTMLElement>('[data-ws-load]');
    if (!sites.length) return;

    let i = 0;
    let timer: number | undefined;

    const runLoadbar = () => {
      if (!loadbar || PREFERS_REDUCED) return;
      loadbar.classList.remove('is-run');
      void loadbar.offsetWidth; // reinicia la animación
      loadbar.classList.add('is-run');
    };

    const show = (n: number) => {
      i = (n + sites.length) % sites.length;
      sites.forEach((s, k) => s.classList.toggle('is-active', k === i));
      pills.forEach((p, k) => {
        const on = k === i;
        p.classList.toggle('is-active', on);
        p.setAttribute('aria-pressed', String(on));
      });
      if (urlEl) urlEl.textContent = sites[i].dataset.url || '';
      // tiñe orbs y barra de carga con el acento del rubro activo
      root.style.setProperty('--acc', sites[i].style.getPropertyValue('--acc'));
      root.style.setProperty('--acc2', sites[i].style.getPropertyValue('--acc2'));
      runLoadbar();
    };

    const stop = () => { if (timer) { clearInterval(timer); timer = undefined; } };
    const start = () => {
      stop();
      if (!PREFERS_REDUCED) timer = window.setInterval(() => show(i + 1), DELAY);
    };

    pills.forEach((p, k) => p.addEventListener('click', () => { show(k); start(); }));

    show(0);

    // Arranca/pausa según visibilidad en viewport.
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) start(); else stop(); });
    }, { threshold: 0.35 });
    io.observe(root);
  });
</script>
