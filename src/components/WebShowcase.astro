---
// Mini-navegador para el hero de "Web y sistemas".
// Concepto: "Cambia de rubro y míralo", cada rubro muestra un MODELO de web
// distinto (carta, reserva de citas, sitio corporativo, e-commerce, portafolio)
// con dirección de arte propia: fondo, tipografía e ilustración distintos por
// rubro (la clínica y la tienda van en modo claro).
// Cicla solo y las pills permiten saltar.
// Autónomo (IntersectionObserver). Respeta prefers-reduced-motion.

const rubros = [
  {
    pill: 'Restaurante', layout: 'menu', initial: 'S', name: 'Sabor Local',
    url: 'sabor-local.pe', acc: '#e0823f', acc2: '#f2b477',
    bg: 'radial-gradient(120% 90% at 85% 0%, rgba(224,130,63,0.16), transparent 60%), linear-gradient(175deg, #2b1d13, #201509)',
    ink: '#f5ead9', mut: '#bfa78d', card: 'rgba(255,240,220,0.05)', line: 'rgba(245,234,217,0.16)',
    nav: ['Carta', 'Reservas', 'Nosotros'],
    tag: 'Cocina peruana', title: 'Reserva tu mesa', cta: 'Reservar',
    items: [
      { n: 'Lomo saltado', d: 'El clásico de la casa', p: 'S/ 38',
        art: '<circle cx="12" cy="13" r="8"/><path d="M8.5 13c1.4-1.8 5.6-1.8 7 0"/><path d="M10 6c0-1 .7-1.2.7-2.2M13.3 6c0-1 .7-1.2.7-2.2"/>' },
      { n: 'Ceviche mixto', d: 'Pescado fresco del día', p: 'S/ 42',
        art: '<path d="M4 11h16a8 8 0 0 1-16 0Z"/><path d="M8.5 8c2-1.8 5-1.8 7 0"/><circle cx="18.5" cy="4.5" r="1.8"/>' },
      { n: 'Ají de gallina', d: 'Receta tradicional', p: 'S/ 30',
        art: '<circle cx="12" cy="13" r="8"/><path d="M9.5 12.5c0 2.2 5 2.2 5 0"/><path d="M12 5.5V3"/>' },
    ],
  },
  {
    pill: 'Clínica', layout: 'booking', initial: 'V', name: 'Clínica Vida',
    url: 'clinica-vida.pe', acc: '#2f7fd6', acc2: '#6db1f0',
    bg: 'radial-gradient(120% 90% at 85% 0%, rgba(47,127,214,0.10), transparent 60%), linear-gradient(180deg, #ffffff, #edf4fb)',
    ink: '#16283c', mut: '#5b7186', card: '#ffffff', line: 'rgba(22,40,60,0.14)',
    nav: ['Especialidades', 'Doctores', 'Citas'],
    tag: 'Atención integral', title: 'Agenda tu cita', cta: 'Confirmar cita',
    specs: ['Medicina general', 'Pediatría', 'Cardiología', 'Odontología'],
    slots: ['09:00', '10:30', '12:00', '16:00'],
  },
  {
    pill: 'Legal', layout: 'legal', initial: 'L', name: 'Lex Asociados',
    url: 'lex-asociados.pe', acc: '#c9a45c', acc2: '#e3c98f',
    bg: 'radial-gradient(120% 90% at 85% 0%, rgba(201,164,92,0.12), transparent 60%), linear-gradient(180deg, #17141c, #0d0b10)',
    ink: '#ece7dc', mut: '#96907f', card: 'rgba(236,231,220,0.04)', line: 'rgba(236,231,220,0.14)',
    nav: ['Áreas', 'Equipo', 'Contacto'],
    tag: 'Estudio jurídico', title: 'Asesoría a tu medida', cta: 'Agendar consulta',
    stats: [{ n: '+20', l: 'años' }, { n: '500+', l: 'casos' }, { n: '98%', l: 'éxito' }],
    areas: ['Derecho corporativo', 'Derecho laboral', 'Derecho civil'],
  },
  {
    pill: 'Tienda', layout: 'shop', initial: 'M', name: 'Mercado Uno',
    url: 'mercado-uno.pe', acc: '#0f9d6a', acc2: '#43c894',
    bg: 'linear-gradient(180deg, #f7f7f9, #ececf1)',
    ink: '#1c1c22', mut: '#686872', card: '#ffffff', line: 'rgba(28,28,40,0.12)',
    nav: ['Inicio', 'Catálogo', 'Ofertas'],
    tag: 'Tienda online',
    products: [
      { n: 'Audífonos Pro', p: 'S/ 199', off: '-20%',
        art: '<path d="M5 13a7 7 0 0 1 14 0"/><rect x="4" y="13" width="3.5" height="6" rx="1.5"/><rect x="16.5" y="13" width="3.5" height="6" rx="1.5"/>' },
      { n: 'Mochila urbana', p: 'S/ 129',
        art: '<rect x="6" y="7" width="12" height="13" rx="3"/><path d="M9 7V5a3 3 0 0 1 6 0v2"/><path d="M6 13h12"/>' },
      { n: 'Lámpara LED', p: 'S/ 89',
        art: '<path d="M9 4h6l3 7H6l3-7Z"/><path d="M12 11v6"/><path d="M8 20h8"/>' },
      { n: 'Teclado mini', p: 'S/ 149',
        art: '<rect x="3" y="8" width="18" height="9" rx="2"/><path d="M6.5 11h.01M10 11h.01M13.5 11h.01M17 11h.01M7 14h10"/>' },
    ],
  },
  {
    pill: 'Profesional', layout: 'portfolio', initial: 'M', name: 'María Diseño',
    url: 'maria-diseno.pe', acc: '#f07a3c', acc2: '#f7a86e',
    bg: 'radial-gradient(120% 90% at 85% 0%, rgba(240,122,60,0.14), transparent 60%), linear-gradient(180deg, #1a1518, #100d12)',
    ink: '#f2ede6', mut: '#948d84', card: 'rgba(242,237,230,0.05)', line: 'rgba(242,237,230,0.14)',
    nav: ['Trabajos', 'Sobre mí', 'Contacto'],
    tag: 'Diseñadora freelance', title: 'Proyectos con huella', cta: 'Ver portafolio',
    tilesArt: [
      '<path d="M2 20a10 10 0 0 1 20 0"/><path d="M7 20a5 5 0 0 1 10 0"/>',
      '<circle cx="9" cy="9" r="6"/><circle cx="16.5" cy="16.5" r="3"/>',
      '<path d="M4 20 20 4M4 12l8-8M12 20l8-8"/>',
      '<path d="M8 2c0 5 8 5 8 10s-8 5-8 10"/>',
      '<circle cx="6" cy="6" r="1.6"/><circle cx="12" cy="6" r="1.6"/><circle cx="18" cy="6" r="1.6"/><circle cx="6" cy="12" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="18" cy="12" r="1.6"/><circle cx="6" cy="18" r="1.6"/><circle cx="12" cy="18" r="1.6"/><circle cx="18" cy="18" r="1.6"/>',
      '<path d="M12 4l8 16H4Z"/>',
    ],
  },
];
---

<figure class="ws" data-ws role="img"
  aria-label="Mini-navegador que muestra cinco modelos de web distintos: una carta de restaurante, una reserva de citas para clínica, un sitio corporativo de estudio legal, una tienda online y un portafolio profesional.">
  <span class="ws-orb ws-orb--a" aria-hidden="true"></span>
  <span class="ws-orb ws-orb--b" aria-hidden="true"></span>

  <header class="ws-bar" aria-hidden="true">
    <span class="ws-bar-name">Web y sistemas</span>
    <span class="ws-bar-tag">a tu medida</span>
  </header>

  <div class="ws-browser">
    <div class="ws-chrome" aria-hidden="true">
      <span class="ws-dots"><i></i><i></i><i></i></span>
      <span class="ws-url">
        <svg width="9" height="9" viewBox="0 0 24 24" fill="none">
          <rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="2"/>
          <path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <span data-ws-url>{rubros[0].url}</span>
      </span>
      <span class="ws-loadbar" data-ws-load aria-hidden="true"></span>
    </div>

    <div class="ws-viewport">
      {rubros.map((r, i) => (
        <article
          class={`ws-site ws-site--${r.layout}${i === 0 ? ' is-active' : ''}`}
          data-site
          data-url={r.url}
          style={`--acc:${r.acc};--acc2:${r.acc2};--site-bg:${r.bg};--site-ink:${r.ink};--site-mut:${r.mut};--site-card:${r.card};--site-line:${r.line};`}
        >
          {/* Barra de navegación del sitio (común a todos) */}
          <div class="ws-nav">
            <span class="ws-logo"><span class="ws-logo-chip">{r.initial}</span>{r.name}</span>
            <span class="ws-nav-links">
              {r.nav.map((x) => <i>{x}</i>)}
              {r.layout === 'shop' && (
                <svg class="ws-cart" width="13" height="13" viewBox="0 0 24 24" fill="none">
                  <path d="M4 5h2l1.6 9.4a1 1 0 0 0 1 .8h7.7a1 1 0 0 0 1-.8L20 8H7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="10" cy="19" r="1.3" fill="currentColor"/><circle cx="17" cy="19" r="1.3" fill="currentColor"/>
                </svg>
              )}
            </span>
          </div>

          {/* ── RESTAURANTE · carta ── */}
          {r.layout === 'menu' && (
            <div class="ws-hero-row">
              <div class="ws-hero-txt">
                <span class="ws-eyebrow">{r.tag}</span>
                <h4 class="ws-title">{r.title}</h4>
              </div>
              <span class="ws-cta">{r.cta}<span aria-hidden="true">→</span></span>
            </div>
          )}
          {r.layout === 'menu' && (
            <div class="ws-menu">
              {r.items.map((it) => (
                <div class="ws-menu-row">
                  <span class="ws-thumb">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={it.art} />
                  </span>
                  <span class="ws-menu-info"><b>{it.n}</b><small>{it.d}</small></span>
                  <span class="ws-dotline"></span>
                  <span class="ws-price">{it.p}</span>
                </div>
              ))}
            </div>
          )}

          {/* ── CLÍNICA · reserva de cita ── */}
          {r.layout === 'booking' && (
            <div class="ws-block">
              <span class="ws-eyebrow">{r.tag}</span>
              <h4 class="ws-title">{r.title}</h4>
              <div class="ws-specs">
                {r.specs.map((s) => <span class="ws-spec">{s}</span>)}
              </div>
            </div>
          )}
          {r.layout === 'booking' && (
            <div class="ws-book">
              <span class="ws-book-label">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <rect x="4" y="6" width="16" height="15" rx="2"/><path d="M4 11h16M8 3v5M16 3v5"/>
                  <rect x="8" y="14" width="3" height="3" rx="0.5" fill="currentColor" stroke="none"/>
                </svg>
                Horarios disponibles hoy
              </span>
              <div class="ws-slots">
                {r.slots.map((s, k) => <span class={`ws-slot${k === 1 ? ' is-sel' : ''}`}>{s}</span>)}
              </div>
              <span class="ws-cta ws-cta--block">{r.cta}<span aria-hidden="true">→</span></span>
            </div>
          )}

          {/* ── LEGAL · corporativo ── */}
          {r.layout === 'legal' && (
            <div class="ws-block ws-block--legal">
              <svg class="ws-legal-ic" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 5v14M8 19h8"/><path d="M12 6 6 8m6-2 6 2"/>
                <path d="M6 8l-2 5a2.8 2.8 0 0 0 4 0L6 8Z"/><path d="M18 8l-2 5a2.8 2.8 0 0 0 4 0l-2-5Z"/>
              </svg>
              <span class="ws-eyebrow">{r.tag}</span>
              <h4 class="ws-title">{r.title}</h4>
              <div class="ws-stats">
                {r.stats.map((s) => <span class="ws-stat"><b>{s.n}</b><small>{s.l}</small></span>)}
              </div>
            </div>
          )}
          {r.layout === 'legal' && (
            <ul class="ws-areas" role="list">
              {r.areas.map((a) => <li>{a}</li>)}
            </ul>
          )}
          {r.layout === 'legal' && (
            <span class="ws-cta">{r.cta}<span aria-hidden="true">→</span></span>
          )}

          {/* ── TIENDA · e-commerce ── */}
          {r.layout === 'shop' && (
            <div class="ws-shop-top">
              <span class="ws-eyebrow">{r.tag}</span>
              <span class="ws-search">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
                  <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
                </svg>
                Buscar…
              </span>
            </div>
          )}
          {r.layout === 'shop' && (
            <div class="ws-grid">
              {r.products.map((pr) => (
                <div class="ws-prod">
                  {pr.off && <span class="ws-off">{pr.off}</span>}
                  <span class="ws-prod-img">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={pr.art} />
                  </span>
                  <span class="ws-prod-name">{pr.n}</span>
                  <span class="ws-prod-foot">
                    <span class="ws-price">{pr.p}</span>
                    <span class="ws-add" aria-hidden="true">+</span>
                  </span>
                </div>
              ))}
            </div>
          )}

          {/* ── PROFESIONAL · portafolio ── */}
          {r.layout === 'portfolio' && (
            <div class="ws-port-hero">
              <span class="ws-eyebrow">{r.tag}</span>
              <h4 class="ws-title">{r.title}</h4>
            </div>
          )}
          {r.layout === 'portfolio' && (
            <div class="ws-gallery">
              {r.tilesArt.map((art, k) => (
                <span class={`ws-tile ws-tile--${k}`}>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" set:html={art} />
                </span>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>
  </div>

  <div class="ws-pills" role="group" aria-label="Elegir rubro">
    {rubros.map((r, i) => (
      <button
        type="button"
        class={i === 0 ? 'ws-pill is-active' : 'ws-pill'}
        data-pill
        style={`--acc:${r.acc};`}
        aria-pressed={i === 0 ? 'true' : 'false'}
      >{r.pill}</button>
    ))}
  </div>
</figure>

<style>
  .ws {
    --acc: var(--primary);
    --acc2: var(--primary-soft);
    position: relative;
    margin: 0;
    aspect-ratio: 1 / 1.05;
    max-height: min(78vh, 600px);
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 0.85rem;
    border-radius: var(--radius, 16px);
    border: 1px solid var(--line-strong);
    overflow: hidden;
    isolation: isolate;
    background:
      radial-gradient(120% 80% at 80% 0%, var(--primary-glow), transparent 58%),
      linear-gradient(180deg, rgba(22, 16, 44, 0.96), rgba(12, 9, 26, 0.97));
    box-shadow: 0 30px 70px -34px rgba(0, 0, 0, 0.7);
  }

  /* ── Orbs ambientales ── */
  .ws-orb {
    position: absolute; z-index: 0;
    width: 60%; aspect-ratio: 1;
    border-radius: 50%;
    filter: blur(46px);
    opacity: 0.5;
    pointer-events: none;
    transition: background 0.8s ease;
  }
  .ws-orb--a { top: -14%; right: -10%; background: radial-gradient(circle, var(--acc), transparent 68%); animation: wsFloatA 14s ease-in-out infinite; }
  .ws-orb--b { bottom: -16%; left: -12%; background: radial-gradient(circle, var(--primary), transparent 68%); animation: wsFloatB 18s ease-in-out infinite; }
  @keyframes wsFloatA { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(-8%, 8%); } }
  @keyframes wsFloatB { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(8%, -6%); } }

  /* ── Barra de etiqueta ── */
  .ws-bar { position: relative; z-index: 2; display: flex; align-items: center; gap: 0.6rem; padding: 0 0.1rem; }
  .ws-bar-name { font-family: var(--serif); font-weight: 600; font-size: 0.84rem; color: var(--ink-100); margin-right: auto; }
  .ws-bar-tag {
    font-family: var(--mono); font-size: 0.56rem; letter-spacing: 0.06em; text-transform: lowercase;
    color: var(--primary-soft);
    padding: 0.22rem 0.5rem;
    border: 1px solid var(--line-strong); border-radius: 999px;
  }

  /* ── Mini-navegador (glass) ── */
  .ws-browser {
    position: relative; z-index: 2;
    flex: 1; min-height: 0;
    display: flex; flex-direction: column;
    border-radius: var(--r-md, 12px);
    border: 1px solid var(--line-strong);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px) saturate(140%);
    -webkit-backdrop-filter: blur(10px) saturate(140%);
    box-shadow: 0 18px 44px -28px rgba(0, 0, 0, 0.7);
  }
  .ws-chrome {
    position: relative;
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.5rem 0.6rem;
    border-bottom: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.02);
  }
  .ws-loadbar {
    position: absolute; left: 0; bottom: -1px;
    height: 2px; width: 0; opacity: 0;
    background: linear-gradient(90deg, var(--acc), var(--acc2, var(--acc)));
    box-shadow: 0 0 8px color-mix(in oklch, var(--acc) 60%, transparent);
  }
  .ws-loadbar.is-run { animation: wsLoad 0.95s cubic-bezier(0.3, 0.7, 0.2, 1); }
  @keyframes wsLoad {
    0% { width: 0; opacity: 1; }
    70% { width: 92%; opacity: 1; }
    100% { width: 100%; opacity: 0; }
  }
  .ws-dots { display: inline-flex; gap: 4px; flex: none; }
  .ws-dots i { width: 7px; height: 7px; border-radius: 50%; background: var(--line-strong); }
  .ws-dots i:first-child { background: rgba(240, 138, 176, 0.6); }
  .ws-dots i:nth-child(2) { background: rgba(240, 184, 106, 0.6); }
  .ws-dots i:nth-child(3) { background: rgba(95, 214, 160, 0.6); }
  .ws-url {
    display: inline-flex; align-items: center; gap: 0.32rem;
    flex: 1; min-width: 0;
    padding: 0.22rem 0.55rem;
    font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.01em;
    color: var(--ink-60);
    background: rgba(0, 0, 0, 0.22);
    border: 1px solid var(--line);
    border-radius: 999px;
  }
  .ws-url [data-ws-url] { color: var(--ink-80); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  /* ── Viewport con los sitios apilados ── */
  .ws-viewport { position: relative; flex: 1; min-height: 0; }
  .ws-site {
    /* Esquema por defecto (oscuro); cada rubro lo pisa vía inline style */
    --site-ink: var(--ink-100);
    --site-mut: var(--ink-60);
    --site-card: rgba(255, 255, 255, 0.03);
    --site-line: var(--line);
    position: absolute; inset: 0;
    display: flex; flex-direction: column; gap: 0.6rem;
    padding: clamp(0.7rem, 2.4vw, 1rem);
    background: var(--site-bg);
    opacity: 0; transform: translateX(22px) scale(0.985);
    transition: opacity 0.9s ease, transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }
  .ws-site.is-active { opacity: 1; transform: none; pointer-events: auto; }

  /* Contenido escalonado, como si la página se renderizara */
  .ws-site > * {
    opacity: 0; transform: translateY(10px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ws-site.is-active > * { opacity: 1; transform: none; }
  .ws-site.is-active > *:nth-child(1) { transition-delay: 0.14s; }
  .ws-site.is-active > *:nth-child(2) { transition-delay: 0.26s; }
  .ws-site.is-active > *:nth-child(3) { transition-delay: 0.38s; }
  .ws-site.is-active > *:nth-child(4) { transition-delay: 0.50s; }

  /* ── Nav del sitio (común) ── */
  .ws-nav { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
  .ws-logo { display: inline-flex; align-items: center; gap: 0.45rem; font-family: var(--serif); font-weight: 600; font-size: 0.8rem; color: var(--site-ink); }
  .ws-logo-chip {
    flex: none; display: grid; place-items: center;
    width: 24px; height: 24px; border-radius: 7px;
    font-size: 0.72rem; color: #fff;
    background: linear-gradient(135deg, var(--acc), var(--acc2));
    box-shadow: 0 4px 12px -4px color-mix(in oklch, var(--acc) 60%, transparent);
  }
  .ws-nav-links { display: inline-flex; align-items: center; gap: 0.55rem; }
  .ws-nav-links i { font-family: var(--mono); font-style: normal; font-size: 0.52rem; color: var(--site-mut); white-space: nowrap; }
  .ws-cart { color: var(--acc); margin-left: 0.1rem; }

  /* Títulos / textos compartidos */
  .ws-eyebrow { font-family: var(--mono); font-size: 0.54rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--acc); }
  .ws-title { font-family: var(--serif); font-weight: 600; font-size: clamp(0.95rem, 3vw, 1.25rem); line-height: 1.1; color: var(--site-ink); letter-spacing: -0.01em; }
  .ws-price { font-family: var(--mono); font-size: 0.62rem; color: var(--site-ink); font-weight: 500; }
  .ws-cta {
    align-self: flex-start;
    display: inline-flex; align-items: center; gap: 0.35rem;
    padding: 0.38rem 0.78rem;
    font-size: 0.68rem; font-weight: 600; color: #fff;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--acc), var(--acc2));
    box-shadow: 0 8px 20px -8px color-mix(in oklch, var(--acc) 70%, transparent);
  }
  .ws-cta--block { align-self: stretch; justify-content: center; }
  .ws-block { display: flex; flex-direction: column; gap: 0.32rem; }

  /* ── RESTAURANTE · carta (oscuro cálido, serif cursiva) ── */
  .ws-site--menu .ws-title { font-style: italic; font-weight: 500; }
  .ws-hero-row { display: flex; align-items: flex-end; justify-content: space-between; gap: 0.5rem; }
